# Copy to .env.local and fill in values

# Must point at the same Supabase project as SUPABASE_URL below — some
# domain migrations (drizzle/migrations/*.sql) grant privileges to
# Supabase-specific roles (e.g. service_role) that only exist there.
DATABASE_URL=postgresql://user:password@localhost:5432/app

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

BETTER_AUTH_URL=http://localhost:3000

# From the Supabase project dashboard: Settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
