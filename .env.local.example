# Copy to .env.local and fill in values

# Any reachable Postgres — a local install, or a free hosted instance
# (Neon, Supabase, Railway, etc.).
DATABASE_URL=postgresql://user:password@localhost:5432/app

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

BETTER_AUTH_URL=http://localhost:3000

# Supabase project used for Storage only (this app's Postgres DB is on Neon —
# see src/lib/db/client.ts). From the project dashboard: Settings -> API.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email — password reset). Get a key at resend.dev.
RESEND_API_KEY=
# Must be a Resend-verified sender. For local/dev, Resend's shared test
# address works without domain verification:
EMAIL_FROM=Pipfolio <onboarding@resend.dev>
